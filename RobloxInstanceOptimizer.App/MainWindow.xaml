<Window x:Class="RobloxInstanceOptimizer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Roblox Instance Optimizer"
        MinHeight="640"
        MinWidth="1040"
        Height="720"
        Width="1160"
        Background="#F5F7FB">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="MinWidth" Value="84" />
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,18">
            <StackPanel>
                <TextBlock Text="Roblox Instance Optimizer"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="#172033" />
                <TextBlock Text="Nettoyage RAM automatique type Mem Reduct, priorité CPU et allocation de coeurs par instance Roblox."
                           Margin="0,5,0,0"
                           Foreground="#536072" />
            </StackPanel>
            <Border DockPanel.Dock="Right"
                    Background="#EAF0FF"
                    BorderBrush="#C7D6FF"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12,8">
                <TextBlock x:Name="AdminStatusText"
                           Foreground="#284170"
                           FontWeight="SemiBold" />
            </Border>
        </DockPanel>

        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#D8DEE9"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14"
                Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Scanner"
                        Click="RefreshButton_Click" />
                <Button Grid.Column="1"
                        Content="Appliquer sélection"
                        Click="ApplySelectedButton_Click" />
                <Button Grid.Column="2"
                        Content="Appliquer tout"
                        Click="ApplyAllButton_Click" />
                <CheckBox Grid.Column="3"
                          x:Name="AutoRefreshCheckBox"
                          Content="Auto-scan"
                          IsChecked="True"
                          VerticalAlignment="Center"
                          Margin="12,0,0,0" />
                <CheckBox Grid.Column="4"
                          x:Name="AutoTrimCheckBox"
                          Content="Nettoyage RAM auto"
                          IsChecked="True"
                          VerticalAlignment="Center"
                          Margin="16,0,0,0" />
                <TextBlock Grid.Column="5"
                           x:Name="StatusText"
                           TextAlignment="Right"
                           Foreground="#536072" />
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#D8DEE9"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14"
                Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Defaut RAM (Mo)"
                           Margin="0,0,8,0"
                           Foreground="#536072" />
                <TextBox Grid.Column="1"
                         x:Name="DefaultMemoryThresholdTextBox" />
                <TextBlock Grid.Column="2"
                           Text="Coeurs"
                           Margin="14,0,8,0"
                           Foreground="#536072" />
                <TextBox Grid.Column="3"
                         x:Name="DefaultCoreCountTextBox" />
                <TextBlock Grid.Column="4"
                           Text="Priorite"
                           Margin="14,0,8,0"
                           Foreground="#536072" />
                <ComboBox Grid.Column="5"
                          x:Name="DefaultPriorityComboBox"
                          ItemsSource="{Binding PriorityOptions}"
                          Padding="8,4" />
                <CheckBox Grid.Column="6"
                          x:Name="AutoApplyDefaultsCheckBox"
                          Content="Appliquer aux nouvelles instances"
                          IsChecked="True"
                          VerticalAlignment="Center"
                          Margin="16,0,0,0" />
                <CheckBox Grid.Column="7"
                          x:Name="AutoDistributeCoresCheckBox"
                          Content="Repartir coeurs auto"
                          IsChecked="True"
                          VerticalAlignment="Center"
                          Margin="16,0,0,0" />
                <Button Grid.Column="8"
                        Content="Sauvegarder defauts"
                        Click="SaveDefaultsButton_Click"
                        Margin="16,0,8,0" />
                <Button Grid.Column="9"
                        Content="Mettre sur tout"
                        HorizontalAlignment="Left"
                        Click="ApplyDefaultsToAllButton_Click" />
            </Grid>
        </Border>

        <DataGrid Grid.Row="3"
                  x:Name="InstancesGrid"
                  ItemsSource="{Binding Instances}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  SelectionMode="Extended"
                  Background="White"
                  BorderBrush="#D8DEE9"
                  BorderThickness="1"
                  RowHeaderWidth="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="PID"
                                    Binding="{Binding ProcessId}"
                                    IsReadOnly="True"
                                    Width="80" />
                <DataGridTextColumn Header="Fenêtre / compte"
                                    Binding="{Binding DisplayName}"
                                    IsReadOnly="True"
                                    Width="2*" />
                <DataGridTextColumn Header="RAM actuelle"
                                    Binding="{Binding MemoryText}"
                                    IsReadOnly="True"
                                    Width="120" />
                <DataGridTemplateColumn Header="Seuil nettoyage (Mo)" Width="160">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding MemoryLimitMb, UpdateSourceTrigger=PropertyChanged}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Coeurs" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding CoreCount, UpdateSourceTrigger=PropertyChanged}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Depart" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding StartCore, UpdateSourceTrigger=PropertyChanged}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Priorité" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding DataContext.PriorityOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                      SelectedItem="{Binding PriorityClass}"
                                      Padding="8,4" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Affinité"
                                    Binding="{Binding AffinityText}"
                                    IsReadOnly="True"
                                    Width="120" />
                <DataGridTextColumn Header="Statut"
                                    Binding="{Binding Status}"
                                    IsReadOnly="True"
                                    Width="2*" />
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="4"
                Background="#FFF7E8"
                BorderBrush="#E8C675"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12"
                Margin="0,14,0,0">
            <TextBlock Foreground="#6C4F00"
                       TextWrapping="Wrap"
                       Text="Note: ce mode ne bloque plus la RAM. Quand une instance dépasse le seuil, l'app demande à Windows de vider une partie de sa mémoire active, comme Mem Reduct. Roblox peut remonter ensuite, donc le nettoyage se répète automatiquement." />
        </Border>
    </Grid>
</Window>
